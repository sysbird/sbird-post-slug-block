{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "create-block/sbird-post-slug-block",
	"extends": "core/paragraph",
	"version": "1.0",
	"title": "sBird Post Slug Block",
	"category": "block",
	"description": "This block displays the slugs for posts, categories, and custom post types.",
	"example": {},
	"supports": {
		"html": false,
		"align": true,
		"color": {
			"text": true,
			"background": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"textColumns": true,
			"textIndent": true,
			"__experimentalFontFamily": true,
			"__experimentalTextDecoration": true,
			"__experimentalFontStyle": true,
			"__experimentalFontWeight": true,
			"__experimentalLetterSpacing": true,
			"__experimentalTextTransform": true,
			"__experimentalWritingMode": true,
			"fitText": true,
			"__experimentalDefaultControls": {
				"fontSize": true
			}
		}
	},
	"selectors": {
		"root": "p",
		"typography": {
			"textIndent": ".wp-block-paragraph + .wp-block-paragraph"
		}
	},
	"attributes": {
		"style": {
			"type": "object"
		},
		"content": {
			"type": "string",
			"source": "html",
			"selector": "p"
		}
	},
	"textdomain": "sbird-post-slug-block",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
